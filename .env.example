# Local: copy to .env — never commit .env
# Railway: set these in Project → Variables (no .env file on server)

# APP_PASSWORD — set only in Railway Variables (not used locally)

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Dataset — local xlsx (default: brand_trust_dataset.xlsx in project root)
# DATASET_PATH=/path/to/brand_trust_dataset.xlsx

# Dataset — Google Drive (overrides local when both set)
# GOOGLE_DRIVE_DATASET_FILE_ID=your-drive-file-id
# GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
# GOOGLE_DRIVE_DATASET_FILENAME=brand_trust_dataset.xlsx

# Google Maps / Places
